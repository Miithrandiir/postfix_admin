<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <title>Postfix Admin - {% block title %}Welcome!{% endblock %}</title>
        <meta name="viewport" content="width=device-width, initial-scale=1">
        {# Run `composer require symfony/webpack-encore-bundle`
           and uncomment the following Encore helpers to start using Symfony UX #}
        {% block stylesheets %}
            {{ encore_entry_link_tags('main') }}
        {% endblock %}

        {% block javascripts %}
            {{ encore_entry_script_tags('app') }}
            {{ encore_entry_script_tags('loader') }}
        {% endblock %}
    </head>
    <body>
        {% block body %}{% endblock %}

        <div id="loader">
            <p>The content is loading ...</p>

            <div class="spinner">
                <div class="inner"></div>
            </div>

        </div>
    </body>
</html>
