{% extends 'administration/admin_base.html.twig' %}

{% block title %}{{ 'Page.UsersEdition.users_edit'|trans }}{% endblock %}

{% block right %}

    <header>
        <h1>{{ 'Page.UsersEdition.users_edit'|trans }}</h1>
    </header>

    <div class="content" id="user_creation">

        <table>
            <thead>
                <tr>
                    <th>#</th>
                    <th>{{ 'General.username'|trans }}</th>
                    <th>{{ 'Page.UsersEdition.nb_domains'|trans }}</th>
                    <th>{{ 'Page.UsersEdition.nb_mailboxes'|trans }}</th>
                </tr>
            </thead>
            <tbody>
                {% for user in users %}

                    <tr>
                        <td>{{ user.id }}</td>
                        <td>{{ user.username }}</td>
                        <td><span>{{ user.domains.count }}</span></td>
                        <td><span>{{ user.mailboxes.count }}</span></td>
                    </tr>

                {% endfor %}
            </tbody>
        </table>

    </div>

{% endblock %}
